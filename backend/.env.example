# IA Generativa — Gemini Flash
# Crie em: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Autenticação JWT
JWT_SECRET_KEY=your_very_secret_key_here_min_32_chars
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# Banco de dados
# Local (SQLite):
DATABASE_URL=sqlite:///./stockops.db
# Produção (Supabase PostgreSQL):
# DATABASE_URL=postgresql://postgres:[senha]@[host]:5432/postgres

# Frontend URL (para CORS e links de email)
# Local:
ALLOWED_ORIGINS=http://localhost:3000
FRONTEND_URL=http://localhost:3000
# Produção (Vercel):
# ALLOWED_ORIGINS=https://seu-projeto.vercel.app
# FRONTEND_URL=https://seu-projeto.vercel.app

# Email transacional — SMTP Gmail
# Gere um App Password em: https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=stockopsautenticador@gmail.com
SMTP_PASSWORD=your_16_char_app_password_here
