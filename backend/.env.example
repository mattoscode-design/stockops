# IA Generativa — Gemini Flash
# Crie em: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Autenticação JWT
JWT_SECRET_KEY=your_very_secret_key_here_min_32_chars
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# Banco de dados
# Local (SQLite):
DATABASE_URL=sqlite:///./stockops.db
# Produção (Supabase PostgreSQL):
# DATABASE_URL=postgresql://postgres:[senha]@[host]:5432/postgres

# Frontend URL (para CORS e links de email)
# Local:
ALLOWED_ORIGINS=http://localhost:3000
FRONTEND_URL=http://localhost:3000
# Produção (Vercel):
# ALLOWED_ORIGINS=https://seu-projeto.vercel.app
# FRONTEND_URL=https://seu-projeto.vercel.app

# Email transacional — Resend
# Crie uma API key em: https://resend.com/api-keys
# Domínio de envio deve estar verificado no painel Resend (ou use o domínio de teste em dev)
RESEND_API_KEY=re_your_api_key_here
# Remetente verificado no Resend (formato: Nome <email@seudominio.com>)
RESEND_FROM=StockOps <noreply@stockops.app>
